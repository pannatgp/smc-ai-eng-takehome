# OpenAI (LLM + embeddings)
OPENAI_API_KEY=

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://smc:smc@localhost:5432/smc

# Local Pinecone (pinecone-local, no auth needed — value is arbitrary)
PINECONE_API_KEY=pclocal
PINECONE_HOST=http://localhost:5080
PINECONE_INDEX_NAME=sec-filings

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
